		"vite-plugin-solid": "^2.11.12"
	},
	"dependencies": {
		"@solid-primitives/resize-observer": "^2.1.5",
		"konva": "^10.3.0",
		"solid-js": "^1.9.13"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/solid-konva.umd.cjs",
