{
	"name": "solid-konva",
	"version": "0.1.6",
	"description": "Solid.js bindings for Konva.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/lawrencecchen/solid-konva.git"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"serve": "vite preview"
	},
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.9.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
